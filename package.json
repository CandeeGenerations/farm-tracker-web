{
  "name": "farm-tracker-web",
  "version": "1.10.5",
  "private": true,
  "description": "Track your farm!",
  "homepage": "https://github.com/CandeeGenerations/farm-tracker#readme",
  "bugs": {
    "url": "https://github.com/CandeeGenerations/farm-tracker/issues"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:CandeeGenerations/farm-tracker.git"
  },
  "license": "MIT",
  "author": "Candee Generations <admin@candeegenerations.com>",
  "scripts": {
    "eslint": "pnpm --filter farm-tracker-web-client run eslint && pnpm --filter farm-tracker-web-server run eslint",
    "preinstall": "sh scripts/check-versions.sh && npx only-allow pnpm",
    "install:all": "pnpm install; cd client; fnm use; pnpm install; cd ../server; fnm use; pnpm install; pnpm generate; cd ../; fnm use;",
    "install:ci": "pnpm install --ignore-scripts && pnpm --filter farm-tracker-web-client install --ignore-scripts && pnpm --filter farm-tracker-web-server install --ignore-scripts",
    "prepare": "husky",
    "prettier": "pnpm --filter farm-tracker-web-client run prettier && pnpm --filter farm-tracker-web-server run prettier",
    "prettier:ci": "pnpm exec prettier --check .",
    "release": "standard-version -a -- --release-as minor"
  },
  "resolutions": {
    "axios": "^1.13.5",
    "minimatch": "^10.2.3",
    "qs": "^6.14.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@trivago/prettier-plugin-sort-imports": "^6.0.1",
    "husky": "^9.1.7",
    "lerna": "^9.0.5",
    "lint-staged": "^16.3.1",
    "prettier": "^3.7.4",
    "sort-package-json": "^3.6.0",
    "standard-version": "^9.5.0"
  },
  "packageManager": "pnpm@10.30.3+sha512.c961d1e0a2d8e354ecaa5166b822516668b7f44cb5bd95122d590dd81922f606f5473b6d23ec4a5be05e7fcd18e8488d47d978bbe981872f1145d06e9a740017",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  }
}
